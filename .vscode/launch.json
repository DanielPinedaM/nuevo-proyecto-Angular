{
  /** configuracion para poder hacer debugging en VS Code */
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "🐞 debugging en Chrome local host",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "start:local",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "🐞 debugging en Chrome pruebas",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "start:test",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "🐞 debugging en Chrome produccion",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "start:prod",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
