{
  "name": "front",
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "ng": "ng",
    "watch": "ng build --watch --configuration development ",
    "test": "ng test",
    "start:local": "ng serve --configuration=localhost --port=4200",
    "start:prod": "ng serve --configuration=production --port=4200",
    "start:test": "ng serve --configuration=test --port=4200",
    "build:test": "node --max_old_space_size=100000 node_modules/@angular/cli/bin/ng build --aot --configuration=test",
    "build:prod": "node --max_old_space_size=100000 node_modules/@angular/cli/bin/ng build --aot --configuration=production",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@ngneat/overview": "^8.1.0",
    "@ngxpert/hot-toast": "^6.3.0",
    "@primeng/themes": "^21.0.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/luxon": "^3.7.2",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "luxon": "^3.7.2",
    "material-symbols": "^0.45.2",
    "postcss": "^8.5.15",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.9",
    "quill": "^2.0.3",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@spartan-ng/cli": "^1.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~6.0.0",
    "angular-eslint": "22.0.0",
    "eslint": "^10.0.0",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}