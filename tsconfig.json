{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "alwaysStrict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,
    "noUncheckedSideEffectImports": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@spartan-ng/helm/accordion": [
        "./src/shared/design/ui/spartan-ng/accordion/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./src/shared/design/ui/spartan-ng/utils/src/index.ts"
      ],
      "@spartan-ng/helm/alert-dialog": [
        "./src/shared/design/ui/spartan-ng/alert-dialog/src/index.ts"
      ],
      "@spartan-ng/helm/button": [
        "./src/shared/design/ui/spartan-ng/button/src/index.ts"
      ],
      "@spartan-ng/helm/combobox": [
        "./src/shared/design/ui/spartan-ng/combobox/src/index.ts"
      ],
      "@spartan-ng/helm/input-group": [
        "./src/shared/design/ui/spartan-ng/input-group/src/index.ts"
      ],
      "@spartan-ng/helm/input": [
        "./src/shared/design/ui/spartan-ng/input/src/index.ts"
      ],
      "@spartan-ng/helm/textarea": [
        "./src/shared/design/ui/spartan-ng/textarea/src/index.ts"
      ],
      "@spartan-ng/helm/date-picker": [
        "./src/shared/design/ui/spartan-ng/date-picker/src/index.ts"
      ],
      "@spartan-ng/helm/calendar": [
        "./src/shared/design/ui/spartan-ng/calendar/src/index.ts"
      ],
      "@spartan-ng/helm/select": [
        "./src/shared/design/ui/spartan-ng/select/src/index.ts"
      ],
      "@spartan-ng/helm/popover": [
        "./src/shared/design/ui/spartan-ng/popover/src/index.ts"
      ],
      "@spartan-ng/helm/carousel": [
        "./src/shared/design/ui/spartan-ng/carousel/src/index.ts"
      ],
      "@spartan-ng/helm/checkbox": [
        "./src/shared/design/ui/spartan-ng/checkbox/src/index.ts"
      ],
      "@spartan-ng/helm/table": [
        "./src/shared/design/ui/spartan-ng/table/src/index.ts"
      ],
      "@spartan-ng/helm/dialog": [
        "./src/shared/design/ui/spartan-ng/dialog/src/index.ts"
      ],
      "@spartan-ng/helm/drawer": [
        "./src/shared/design/ui/spartan-ng/drawer/src/index.ts"
      ],
      "@spartan-ng/helm/dropdown-menu": [
        "./src/shared/design/ui/spartan-ng/dropdown-menu/src/index.ts"
      ],
      "@spartan-ng/helm/label": [
        "./src/shared/design/ui/spartan-ng/label/src/index.ts"
      ],
      "@spartan-ng/helm/pagination": [
        "./src/shared/design/ui/spartan-ng/pagination/src/index.ts"
      ],
      "@spartan-ng/helm/radio-group": [
        "./src/shared/design/ui/spartan-ng/radio-group/src/index.ts"
      ],
      "@spartan-ng/helm/sheet": [
        "./src/shared/design/ui/spartan-ng/sheet/src/index.ts"
      ],
      "@spartan-ng/helm/sonner": [
        "./src/shared/design/ui/spartan-ng/sonner/src/index.ts"
      ],
      "@spartan-ng/helm/switch": [
        "./src/shared/design/ui/spartan-ng/switch/src/index.ts"
      ],
      "@spartan-ng/helm/tabs": [
        "./src/shared/design/ui/spartan-ng/tabs/src/index.ts"
      ],
      "@spartan-ng/helm/tooltip": [
        "./src/shared/design/ui/spartan-ng/tooltip/src/index.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
